{
  "metadata": {
    "version": "1.0",
    "category": "Interface Configuration Commands",
    "last_updated": "2024-01-15",
    "source": "Cisco IOS Interface Command Reference",
    "command_count": 25
  },
  "commands": {
    "interface": {
      "name": "interface",
      "syntax": "interface type number",
      "description": "Configures an interface and enters interface configuration mode",
      "modes": ["global-config"],
      "parameters": {
        "type": {
          "description": "Interface type",
          "valid_values": [
            "GigabitEthernet",
            "FastEthernet",
            "TenGigabitEthernet",
            "Vlan",
            "Loopback",
            "Port-channel",
            "Tunnel"
          ],
          "abbreviations": {
            "Gi": "GigabitEthernet",
            "Fa": "FastEthernet",
            "Te": "TenGigabitEthernet",
            "Vl": "Vlan",
            "Lo": "Loopback",
            "Po": "Port-channel"
          }
        },
        "number": {
          "description": "Interface number",
          "format": "slot/port or just number (depends on platform)",
          "examples": ["0/1", "1/0/1", "10", "100"]
        }
      },
      "examples": [
        {
          "command": "interface GigabitEthernet0/1",
          "description": "Configure GigabitEthernet interface 0/1"
        },
        {
          "command": "interface Vlan90",
          "description": "Configure VLAN interface 90 (SVI)",
          "context": "Management VLAN"
        },
        {
          "command": "interface FastEthernet0/1",
          "description": "Configure FastEthernet interface"
        }
      ],
      "related_commands": [
        "interface range",
        "show interfaces",
        "show ip interface brief"
      ],
      "best_practices": [
        "Always add description to interfaces",
        "Use consistent naming (full names vs abbreviations)",
        "Document interface purpose"
      ],
      "common_in_configs": true
    },
    "interface range": {
      "name": "interface range",
      "syntax": "interface range type slot/port - port [, type slot/port - port]",
      "description": "Configures a range of interfaces with the same parameters",
      "modes": ["global-config"],
      "parameters": {
        "range": {
          "description": "Range of interfaces",
          "format": "type slot/start-port - end-port",
          "examples": [
            "FastEthernet0/1 - 24",
            "GigabitEthernet0/1 - 2"
          ]
        }
      },
      "examples": [
        {
          "command": "interface range FastEthernet0/4-24",
          "description": "Configure FastEthernet ports 4 through 24 simultaneously",
          "use_case": "Bulk configuration of unused ports"
        },
        {
          "command": "interface range GigabitEthernet0/1 - 2",
          "description": "Configure both GigabitEthernet interfaces"
        }
      },
      "best_practices": [
        "Use for bulk operations (shutdown unused ports, VLAN assignment)",
        "Verify range before applying configuration",
        "Test on one interface first if unsure"
      ],
      "common_mistakes": [
        "Incorrect range syntax (use space before hyphen)",
        "Mixing interface types in same range",
        "Applying wrong config to production ports"
      ],
      "related_commands": [
        "interface",
        "show interfaces status"
      ],
      "common_in_configs": true
    },
    "description": {
      "name": "description",
      "syntax": "description string",
      "description": "Adds a description to an interface",
      "modes": ["interface-config"],
      "parameters": {
        "string": {
          "description": "Description text",
          "max_length": "240 characters",
          "format": "Free text"
        }
      },
      "examples": [
        {
          "command": "description PC4-Access port",
          "description": "Label for user access port",
          "context": "From your config"
        },
        {
          "command": "description dis-venstre-sw01 gig0/1",
          "description": "Uplink to distribution switch",
          "context": "Trunk port documentation"
        },
        {
          "command": "description Management SVI",
          "description": "Management VLAN interface"
        }
      },
      "best_practices": [
        "Always add descriptions to all interfaces",
        "Include: connected device, purpose, or contact info",
        "Use consistent format across network",
        "For uplinks: include remote device and interface",
        "For access ports: include connected device or room number"
      ],
      "common_formats": [
        "Device name and port: 'dis-switch-01 Gi0/1'",
        "Purpose: 'User Access - PC4'",
        "Location: 'Room 101 - Workstation'",
        "Circuit ID: 'WAN Link - Circuit ABC123'"
      ],
      "related_commands": [
        "interface",
        "show interfaces description"
      ],
      "common_in_configs": true
    },
    "shutdown": {
      "name": "shutdown",
      "syntax": "shutdown",
      "description": "Disables an interface",
      "modes": ["interface-config"],
      "parameters": {},
      "examples": [
        {
          "command": "shutdown",
          "description": "Administratively disable interface",
          "context": "Securing unused ports"
        }
      },
      "security_considerations": [
        "Always shutdown unused interfaces",
        "Prevents unauthorized network access",
        "Required by many security standards (PCI-DSS, etc.)"
      ],
      "best_practices": [
        "Shutdown all unused interfaces",
        "Add description before shutdown (document why)",
        "Review regularly for ports that can be re-enabled",
        "Combine with other security features on access ports"
      ],
      "related_commands": [
        "no shutdown",
        "interface range"
      ],
      "common_in_configs": true
    },
    "no shutdown": {
      "name": "no shutdown",
      "syntax": "no shutdown",
      "description": "Enables an interface",
      "modes": ["interface-config"],
      "parameters": {},
      "examples": [
        {
          "command": "no shutdown",
          "description": "Activate interface",
          "context": "Enabling a configured interface"
        }
      },
      "best_practices": [
        "Configure interface fully before issuing 'no shutdown'",
        "Verify configuration with 'show run interface' first",
        "Document when and why interface was enabled"
      ],
      "related_commands": [
        "shutdown",
        "show interfaces status"
      ],
      "common_in_configs": true
    },
    "switchport mode": {
      "name": "switchport mode",
      "syntax": "switchport mode {access | trunk | dynamic {auto | desirable}}",
      "description": "Sets the interface mode to access, trunk, or dynamic",
      "modes": ["interface-config"],
      "parameters": {
        "mode": {
          "description": "Interface switching mode",
          "values": {
            "access": "Access mode - for end devices, single VLAN",
            "trunk": "Trunk mode - carries multiple VLANs",
            "dynamic auto": "Passively negotiate trunking (not recommended)",
            "dynamic desirable": "Actively negotiate trunking (not recommended)"
          }
        }
      },
      "examples": [
        {
          "command": "switchport mode access",
          "description": "Configure as access port for end device",
          "context": "PC, printer, phone, etc."
        },
        {
          "command": "switchport mode trunk",
          "description": "Configure as trunk port",
          "context": "Switch-to-switch links"
        }
      },
      "security_considerations": [
        "Never use dynamic modes in production",
        "Explicitly configure 'access' or 'trunk'",
        "Dynamic modes vulnerable to VLAN hopping attacks",
        "Use 'switchport nonegotiate' on trunk ports"
      ],
      "best_practices": [
        "Always use explicit 'access' or 'trunk' mode",
        "Never rely on dynamic negotiation (DTP)",
        "Disable DTP with 'switchport nonegotiate'",
        "Access ports: for end devices",
        "Trunk ports: only for switch-to-switch/router links"
      ],
      "common_mistakes": [
        "Using dynamic modes (security risk)",
        "Not disabling DTP on trunk ports",
        "Configuring trunk mode on access ports by mistake"
      ],
      "related_commands": [
        "switchport access vlan",
        "switchport trunk allowed vlan",
        "switchport nonegotiate"
      ],
      "common_in_configs": true
    },
    "switchport access vlan": {
      "name": "switchport access vlan",
      "syntax": "switchport access vlan vlan-id",
      "description": "Assigns an interface to a VLAN when in access mode",
      "modes": ["interface-config"],
      "prerequisites": [
        "Interface must be in access mode",
        "VLAN must exist (will be created if not)"
      ],
      "parameters": {
        "vlan-id": {
          "description": "VLAN number",
          "range": "1-4094",
          "note": "VLAN 1 is default"
        }
      },
      "examples": [
        {
          "command": "switchport access vlan 11",
          "description": "Assign port to VLAN 11",
          "context": "User access port"
        },
        {
          "command": "switchport access vlan 90",
          "description": "Assign to management VLAN",
          "context": "Management PC port"
        }
      },
      "best_practices": [
        "Avoid using VLAN 1 for user traffic",
        "Document VLAN assignments",
        "Use consistent VLAN numbering scheme",
        "Create VLAN before assigning (for clarity)"
      ],
      "related_commands": [
        "switchport mode access",
        "vlan",
        "show vlan brief"
      ],
      "common_in_configs": true
    },
    "switchport trunk encapsulation": {
      "name": "switchport trunk encapsulation",
      "syntax": "switchport trunk encapsulation {dot1q | isl | negotiate}",
      "description": "Sets the trunk encapsulation method",
      "modes": ["interface-config"],
      "availability": "Only on platforms that support multiple encapsulation types",
      "parameters": {
        "encapsulation": {
          "description": "Trunk encapsulation type",
          "values": {
            "dot1q": "IEEE 802.1Q (industry standard)",
            "isl": "Cisco ISL (deprecated, Cisco proprietary)",
            "negotiate": "Negotiate encapsulation (not recommended)"
          }
        }
      },
      "examples": [
        {
          "command": "switchport trunk encapsulation dot1q",
          "description": "Use 802.1Q encapsulation",
          "context": "Standard trunk configuration"
        }
      },
      "best_practices": [
        "Always use dot1q (industry standard)",
        "ISL is deprecated, avoid using",
        "Required before 'switchport mode trunk' on some platforms"
      ],
      "related_commands": [
        "switchport mode trunk",
        "switchport trunk native vlan"
      ],
      "platform_notes": [
        "Not available on all platforms (e.g., Catalyst 2960 only supports dot1q)",
        "Required on Catalyst 3560, 3750 before setting trunk mode"
      ],
      "common_in_configs": true
    },
    "switchport trunk native vlan": {
      "name": "switchport trunk native vlan",
      "syntax": "switchport trunk native vlan vlan-id",
      "description": "Sets the native VLAN for 802.1Q trunk",
      "modes": ["interface-config"],
      "parameters": {
        "vlan-id": {
          "description": "Native VLAN number",
          "range": "1-4094",
          "default": "1"
        }
      },
      "examples": [
        {
          "command": "switchport trunk native vlan 666",
          "description": "Set native VLAN to 666",
          "context": "Security hardening - unused VLAN as native"
        }
      },
      "security_considerations": [
        "Change native VLAN from default (1)",
        "Use dedicated unused VLAN as native",
        "Native VLAN must match on both ends of trunk",
        "Native VLAN mismatch causes CDP/VTP issues"
      ],
      "best_practices": [
        "Never use VLAN 1 as native VLAN",
        "Use unused VLAN as native (e.g., 999, 666)",
        "Ensure consistency across trunk links",
        "Document native VLAN standard"
      ],
      "common_mistakes": [
        "Native VLAN mismatch between switches",
        "Forgetting to change native VLAN",
        "Using active VLAN as native"
      ],
      "related_commands": [
        "switchport trunk encapsulation dot1q",
        "switchport mode trunk",
        "switchport trunk allowed vlan"
      ],
      "common_in_configs": true
    },
    "switchport trunk allowed vlan": {
      "name": "switchport trunk allowed vlan",
      "syntax": "switchport trunk allowed vlan {vlan-list | add vlan-list | remove vlan-list | except vlan-list | all | none}",
      "description": "Specifies which VLANs are allowed on the trunk",
      "modes": ["interface-config"],
      "parameters": {
        "vlan-list": {
          "description": "VLAN numbers and ranges",
          "format": "1,2,5-10,20",
          "examples": ["11,12,90", "10-20,30,40-50"]
        },
        "add": {
          "description": "Add VLANs to existing list"
        },
        "remove": {
          "description": "Remove VLANs from existing list"
        },
        "except": {
          "description": "All VLANs except specified"
        },
        "all": {
          "description": "Allow all VLANs (1-4094)"
        },
        "none": {
          "description": "No VLANs allowed"
        }
      },
      "examples": [
        {
          "command": "switchport trunk allowed vlan 11,12,90",
          "description": "Allow only VLANs 11, 12, and 90",
          "context": "From your actual config - access switch trunk"
        },
        {
          "command": "switchport trunk allowed vlan add 100",
          "description": "Add VLAN 100 to existing allowed list"
        },
        {
          "command": "switchport trunk allowed vlan remove 999",
          "description": "Remove VLAN 999 from allowed list"
        }
      },
      "security_considerations": [
        "Only allow necessary VLANs on each trunk",
        "Never use 'switchport trunk allowed vlan all'",
        "Prune unused VLANs to limit broadcast domain",
        "Reduces attack surface"
      ],
      "best_practices": [
        "Explicitly list only required VLANs",
        "Use 'add' and 'remove' for modifications",
        "Document VLAN pruning strategy",
        "Review trunk VLAN lists periodically",
        "Include native VLAN in allowed list"
      ],
      "common_mistakes": [
        "Using 'all' instead of explicit list",
        "Forgetting to include native VLAN",
        "Not pruning unused VLANs"
      ],
      "related_commands": [
        "switchport mode trunk",
        "show interfaces trunk",
        "vlan"
      ],
      "common_in_configs": true
    },
    "switchport nonegotiate": {
      "name": "switchport nonegotiate",
      "syntax": "switchport nonegotiate",
      "description": "Disables DTP (Dynamic Trunking Protocol) on the interface",
      "modes": ["interface-config"],
      "parameters": {},
      "examples": [
        {
          "command": "switchport nonegotiate",
          "description": "Disable DTP negotiation",
          "context": "Security hardening on trunk ports"
        }
      },
      "security_considerations": [
        "DTP can be exploited for VLAN hopping attacks",
        "Always disable DTP on trunk ports",
        "Required for PCI-DSS compliance",
        "Prevents unauthorized trunk formation"
      ],
      "best_practices": [
        "Configure on all trunk ports",
        "Part of switch hardening checklist",
        "Combine with explicit trunk mode configuration"
      ],
      "related_commands": [
        "switchport mode trunk",
        "show interfaces switchport"
      ],
      "common_in_configs": true
    },
    "switchport port-security": {
      "name": "switchport port-security",
      "syntax": "switchport port-security",
      "description": "Enables port security on the interface",
      "modes": ["interface-config"],
      "prerequisites": [
        "Interface must be in access mode or trunk mode",
        "Access mode recommended for port security"
      ],
      "parameters": {},
      "examples": [
        {
          "command": "switchport port-security",
          "description": "Enable port security with default settings",
          "context": "Access port hardening"
        }
      },
      "default_behavior": [
        "Maximum 1 MAC address allowed",
        "Violation action: shutdown",
        "No aging configured",
        "Dynamic MAC learning"
      ],
      "security_considerations": [
        "Prevents MAC flooding attacks",
        "Limits devices per port",
        "Must be configured properly to avoid lockouts"
      ],
      "best_practices": [
        "Enable on all access ports",
        "Configure maximum MAC addresses appropriately",
        "Use 'sticky' MAC learning",
        "Set appropriate violation action",
        "Configure aging for flexibility"
      ],
      "related_commands": [
        "switchport port-security maximum",
        "switchport port-security violation",
        "switchport port-security mac-address sticky",
        "switchport port-security aging"
      ],
      "common_in_configs": true
    },
    "switchport port-security maximum": {
      "name": "switchport port-security maximum",
      "syntax": "switchport port-security maximum value",
      "description": "Sets maximum number of secure MAC addresses on the port",
      "modes": ["interface-config"],
      "parameters": {
        "value": {
          "description": "Maximum number of MAC addresses",
          "range": "1-3072 (platform dependent)",
          "default": "1",
          "typical": "1 for PC, 2-3 for IP phone + PC"
        }
      },
      "examples": [
        {
          "command": "switchport port-security maximum 1",
          "description": "Allow only 1 MAC address (single device)",
          "context": "Standard PC access port"
        },
        {
          "command": "switchport port-security maximum 2",
          "description": "Allow 2 MAC addresses",
          "context": "IP phone + PC"
        }
      },
      "best_practices": [
        "Use maximum 1 for standard access ports",
        "Use maximum 2 for ports with IP phones",
        "Never set higher than necessary",
        "Document rationale for values > 1"
      ],
      "related_commands": [
        "switchport port-security",
        "show port-security"
      ],
      "common_in_configs": true
    }
  }
}
