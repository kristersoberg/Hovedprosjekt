{
  "llm": {
    "endpoint": "http://192.168.1.174:11434/v1/chat/completions",
    "model": "qwen2.5:32b-instruct-q5_K_M",
    "max_tokens": 16000,
    "temperature": 0.1,
    "top_p": 0.9,
    "num_ctx": 32768
  },
  "logging": {
    "enabled": true,
    "log_dir": "./logs",
    "verbose": false,
    "debug": false
  },
  "git": {
    "enabled": true,
    "auto_push": true,
    "remote": "origin",
    "branch": "master"
  },
  "processing": {
    "auto_start_on_file_change": true,
    "delete_old_documentation": false
  },
  "validation": {
    "enabled": true,
    "save_reports": true
  },
  "security": {
    "sanitize_secrets": true,
    "redact_passwords": true,
    "redact_snmp_communities": true,
    "redact_tacacs_keys": true
  }
}