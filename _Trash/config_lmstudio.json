{
  "llm": {
    "endpoint": "http://localhost:1234/v1/chat/completions",
    "model": "meta-llama-3.1-8b-instruct",
    "api_key": "",
    "temperature": 0.7,
    "max_tokens": 4000,
    "timeout": 300000
  },
  "mcp": {
    "server_path": "./mcp_server/server.py",
    "enabled": true,
    "max_prompt_size": 50000,
    "max_commands": 2,
    "max_features": 1
  },
  "git": {
    "enabled": true,
    "auto_push": false,
    "remote": "origin",
    "branch": "main"
  },
  "processing": {
    "auto_start_on_file_change": true,
    "delete_old_documentation": false
  }
}
